XTRANS  DFHMSD LANG=COBOL,MODE=INOUT,STORAGE=AUTO,                     X
               TYPE=MAP,CTRL=FREEKB,TIOPFX=YES,DSATTS=(COLOR,HILIGHT), X
               MAPATTS=(COLOR,HILIGHT)
TMAP    DFHMDI SIZE=(18,80),LINE=1,COLUMN=1
        DFHMDF POS=(3,31),INITIAL='KOSGI BANK',LENGTH=10,ATTRB=ASKIP
        DFHMDF POS=(4,56),INITIAL='DATE:',LENGTH=5,ATTRB=ASKIP
DATE    DFHMDF POS=(4,62),LENGTH=10,ATTRB=PROT
        DFHMDF POS=(4,2),INITIAL='SEND MONEY      ',LENGTH=17,         X
               ATTRB=ASKIP
        DFHMDF POS=(7,26),INITIAL='FROM ID:',LENGTH=9,ATTRB=ASKIP
FROMID  DFHMDF POS=(7,35),LENGTH=6,ATTRB=(UNPROT,IC),HILIGHT=UNDERLINE
        DFHMDF POS=(7,42),LENGTH=40,ATTRB=ASKIP
        DFHMDF POS=(10,26),LENGTH=7,INITIAL='TO ID :',ATTRB=ASKIP
TOID    DFHMDF POS=(10,34),LENGTH=6,ATTRB=(UNPROT)
        DFHMDF POS=(10,41),LENGTH=40,ATTRB=ASKIP
        DFHMDF POS=(13,26),LENGTH=7,INITIAL='AMOUNT:',ATTRB=ASKIP
AMOUNT  DFHMDF POS=(13,34),LENGTH=9,ATTRB=(UNPROT)
        DFHMDF POS=(13,44),LENGTH=2,ATTRB=ASKIP
        DFHMDF POS=(14,1),LENGTH=50,ATTRB=ASKIP
MSG     DFHMDF POS=(15,3),LENGTH=30,ATTRB=PROT
        DFHMDF POS=(16,1),LENGTH=50,ATTRB=ASKIP
        DFHMDF POS=(17,1),LENGTH=50,ATTRB=ASKIP
        DFHMSD TYPE=FINAL
                END
